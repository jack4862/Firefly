---
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import type { AnimeItem, AnimeStatus } from "@/types/config";

interface Props extends AnimeItem {}

const { title, titleJa, cover, synopsis, rating, status, year, tags, episodes, link } = Astro.props;

const statusMap: Record<AnimeStatus, { label: string; color: string }> = {
	watching: { label: i18n(I18nKey.animeStatusWatching), color: "bg-green-500" },
	completed: { label: i18n(I18nKey.animeStatusCompleted), color: "bg-blue-500" },
	"on-hold": { label: i18n(I18nKey.animeStatusOnHold), color: "bg-yellow-500" },
	dropped: { label: i18n(I18nKey.animeStatusDropped), color: "bg-red-500" },
	"plan-to-watch": { label: i18n(I18nKey.animeStatusPlanToWatch), color: "bg-purple-500" },
};

const statusInfo = statusMap[status];
---

<div
  class="anime-card group relative overflow-hidden rounded-xl transition-all duration-300 hover:shadow-lg hover:scale-[1.02] card-base"
  data-tags={tags?.join(",") || ""}
  data-status={status}
  data-rating={rating || 0}
  data-year={year || 0}
>
  <a href={link || "#"} target={link ? "_blank" : undefined} rel={link ? "noopener noreferrer" : undefined} class="block">
    <div class="aspect-[3/4] relative overflow-hidden">
      {cover ? (
        <img
          src={cover}
          alt={title}
          class="w-full h-full object-cover pointer-events-none transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="w-full h-full bg-gray-200 dark:bg-gray-700 flex items-center justify-center">
          <div class="text-gray-400 text-5xl">&#x1f3ac;</div>
        </div>
      )}

      <div class={`absolute top-2 left-2 px-2 py-1 rounded-full text-xs text-white font-medium ${statusInfo.color} backdrop-blur-sm`}>
        {statusInfo.label}
      </div>

      {rating !== undefined && rating > 0 && (
        <div class="absolute top-2 right-2 px-2 py-1 rounded-full text-xs text-white font-medium bg-black/50 backdrop-blur-sm flex items-center gap-1">
          <svg class="w-3 h-3 text-yellow-400" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          {rating}
        </div>
      )}

      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent" />
      <div class="absolute bottom-0 left-0 right-0 p-4">
        <h3 class="font-bold text-base text-white line-clamp-2 drop-shadow-lg">
          {title}
        </h3>
        {titleJa && (
          <p class="text-xs text-white/60 line-clamp-1 mt-0.5">{titleJa}</p>
        )}

        <div class="flex items-center gap-3 text-xs text-white/70 mt-1.5 flex-wrap">
          {year && <span>{year}</span>}
          {episodes && (
            <span>{episodes.watched}/{episodes.total} {i18n(I18nKey.animeEpisodes)}</span>
          )}
        </div>

        {tags && tags.length > 0 && (
          <div class="flex flex-wrap gap-1 mt-2">
            {tags.slice(0, 3).map((tag) => (
              <span class="text-[0.6rem] px-1.5 py-0.5 rounded bg-white/20 text-white/90 backdrop-blur-sm">
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>
    </div>
  </a>

  {synopsis && (
    <div class="absolute inset-0 bg-black/85 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center p-4 pointer-events-none">
      <p class="text-white text-sm leading-relaxed line-clamp-6">{synopsis}</p>
    </div>
  )}
</div>
